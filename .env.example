# Polyguard application credentials (visible to the browser).
NEXT_PUBLIC_POLYGUARD_APP_ID=demo-workforce-applications
NEXT_PUBLIC_POLYGUARD_API_SERVER=api.polyguard.ai

# Jotform form ID for your job application. The form must contain a hidden
# field named `polyguard_jwt` and its native Submit button should be hidden
# via Conditions so the only path to submission is the "Submit with
# Polyguard" CTA.
NEXT_PUBLIC_JOTFORM_ID=

# 32-byte base64-encoded webhook decryption secret from the Polyguard
# dashboard. Server-only — never exposed to the browser.
POLYGUARD_WEBHOOK_SECRET=

# Optional. If absent, webhook payloads are kept in an in-process Map
# (fine for `next dev`, broken across Vercel serverless instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
